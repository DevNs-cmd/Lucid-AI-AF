datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  name         String      @default("Explorer")
  password     String      // Securely hashed password
  preferences  Json        // JSON object holding user-defined configurations (preferredGenre, narrativeTone, etc.)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  storyNodes   StoryNode[]

  @@map("users")
}

model World {
  id         String      @id @default(uuid())
  name       String
  weather    String      @default("Clear")
  economy    String      @default("Stable")
  politics   String      @default("Democratic")
  crimeState Int         @default(10) // Scale of 0-100 indicating lawlessness level
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  npcs       NPC[]
  storyNodes StoryNode[]

  @@map("worlds")
}

model NPC {
  id             String   @id @default(uuid())
  worldId        String
  world          World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name           String
  traits         String[] // Array of personality traits e.g. ["Cunning", "Mercenary"]
  occupation     String
  trustLevel     Int      @default(50) // Scale of 0-100 representing NPC trust toward active players
  angerLevel     Int      @default(0)  // Scale of 0-100 representing NPC hostility toward active players
  memoryVectorId String   @unique      // Relates to episodic cognitive buffers in Qdrant collection
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("npcs")
}

model StoryNode {
  id             String   @id @default(uuid())
  worldId        String
  world          World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterTitle   String
  dynamicSummary String   // Summarizes the structural consequences generated by Gemini
  choiceHistory  String[] // History of decisions that led to this structural checkpoint
  createdAt      DateTime @default(now())

  @@map("story_nodes")
}
