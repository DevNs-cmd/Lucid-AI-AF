# ==============================================================================
# General App Configuration
# ==============================================================================
APP_NAME="LUCID AI Backend"
ENVIRONMENT=development
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=replace_with_a_highly_secure_random_hex_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ==============================================================================
# Database Configuration (PostgreSQL 17)
# ==============================================================================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lucid_admin
POSTGRES_PASSWORD=lucid_secure_password
POSTGRES_DB=lucid_db
DATABASE_URL=postgresql+asyncpg://lucid_admin:lucid_secure_password@localhost:5432/lucid_db

# ==============================================================================
# Cache Configuration (Redis)
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Broker Configuration (RabbitMQ / Celery)
# ==============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==============================================================================
# Vector DB Configuration (Qdrant)
# ==============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ==============================================================================
# Third-Party AI Integrations
# ==============================================================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# Telemetry, Monitoring, Logging
# ==============================================================================
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317